{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ 生成活动文件",
            "command": "/usr/bin/g++",
            "args": [
                // "-O3",
                "-Ofast",
                "-march=native",
                "-fdiagnostics-color=always",
                "-g0",
                "${workspaceFolder}/src/compress/*.cc",
                "${workspaceFolder}/src/common/*.cc",
                "*.cc",
                "-I",
                "${workspaceFolder}/src",
                // "-llzma",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                // "-mavx2",
                "-mavx512f",
                "-static",
                // "-fprofile-generate",
                // "-fprofile-use",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}
